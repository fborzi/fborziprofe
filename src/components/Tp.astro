---
import { getSupabase } from "../lib/supabase";

// Definimos la interfaz de las "Props" que recibe el componente
interface Props {
  tpNumber: number; // Ej: 1, 2, 3 o 4
  materia: string;  // Ej: 'python', 'java'
}

const { tpNumber, materia } = Astro.props;

// Creamos un wrapper de solo lectura para las cookies.
const readOnlyCookies = {
  get: (key: string) => Astro.cookies.get(key),
  set: (key: string, value: any, options: any) => { /* Ignorar en renderizado */ },
  delete: (key: string, options: any) => { /* Ignorar en renderizado */ }
};

const supabase = getSupabase(readOnlyCookies);

// Consultamos los ejercicios de ESTE Trabajo Práctico y de ESTA materia
const { data: exercises, error } = await supabase
  .from('exercises')
  .select('*')
  .eq('tp_id', tpNumber)
  .eq('materia', materia) // Filtramos por la materia que pasamos por prop
  .lte('unlock_date', new Date().toISOString()) 
  .order('id', { ascending: true });

if (error) {
  console.error(`Error cargando ejercicios del TP ${tpNumber} de ${materia}:`, error);
}

// Capitalizamos el nombre de la materia para el título (ej: 'python' -> 'Python')
const materiaFormateada = materia.charAt(0).toUpperCase() + materia.slice(1);
---

<div class="max-w-4xl mx-auto px-4 pb-12 pt-4">
    <!-- Encabezado dinámico por TP y Materia -->
    <header class="bg-white/5 border border-white/10 p-6 md:p-8 rounded-3xl text-center mb-10 backdrop-blur-md relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-indigo-500/10 to-purple-500/10 z-0"></div>
        <h2 class="text-white text-3xl md:text-4xl font-extrabold mb-2 tracking-tight relative z-10">
            Trabajo Práctico {tpNumber} - {materiaFormateada}
        </h2>
        <p class="text-gray-400 text-lg relative z-10">
            Ejercicios de resolución de la cátedra
        </p>
    </header>

    <div class="space-y-6 relative">
        <!-- Decoración visual sutil de fondo -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3/4 h-3/4 bg-indigo-500/10 blur-[120px] rounded-full z-[-1] pointer-events-none"></div>

        {error ? (
            <div class="bg-red-500/20 text-red-200 p-6 rounded-xl border border-red-500/30 text-center">
                Hubo un error al cargar los ejercicios del TP {tpNumber}. Intenta recargar la página.
            </div>
        ) : (!exercises || exercises.length === 0) ? (
            <div class="bg-white/5 p-8 rounded-xl border border-white/10 text-center text-gray-400">
                Aún no hay ejercicios habilitados para este TP de {materiaFormateada}. ¡Vuelve pronto!
            </div>
        ) : (
            exercises.map((exercise) => (
                <article class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm shadow-xl transition-all duration-300 hover:bg-white/10">
                    
                    <!-- Título del Ejercicio -->
                    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-5">
                        <span class="bg-white text-black px-4 py-1.5 rounded-full font-bold text-sm shrink-0 shadow-[0_0_15px_rgba(255,255,255,0.3)]">
                            Ejercicio {exercise.id}
                        </span>
                        <h3 class="text-white font-semibold text-lg md:text-xl">{exercise.title}</h3>
                    </div>

                    <!-- Enunciado -->
                    <div class="bg-black/30 p-5 rounded-xl border-l-4 border-indigo-500 text-gray-300 leading-relaxed font-medium">
                        {exercise.description}
                    </div>

                    <!-- Ejemplos de Entrada y Salida (Solo se renderizan si existen en la DB) -->
                    {(exercise.example_input || exercise.example_output) && (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
                            {exercise.example_input && (
                                <div class="bg-black/40 border border-white/5 rounded-xl p-4 font-mono text-sm">
                                    <div class="text-indigo-400 font-bold mb-2 flex items-center gap-2">
                                        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                        Ejemplo de Entrada
                                    </div>
                                    <p class="text-gray-300 whitespace-pre-wrap">{exercise.example_input}</p>
                                </div>
                            )}
                            
                            {exercise.example_output && (
                                <div class="bg-black/40 border border-white/5 rounded-xl p-4 font-mono text-sm">
                                    <div class="text-green-400 font-bold mb-2 flex items-center gap-2">
                                        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                                        Salida Esperada
                                    </div>
                                    <p class="text-gray-300 whitespace-pre-wrap">{exercise.example_output}</p>
                                </div>
                            )}
                        </div>
                    )}
                </article>
            ))
        )}
    </div>
</div>
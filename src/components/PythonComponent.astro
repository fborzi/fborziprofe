---
interface Props {
  tpNumber: number;
  materia: string;
  isOpen?: boolean;
}

const { tpNumber, materia, isOpen = false } = Astro.props;
const supabase = Astro.locals.supabase;

const { data: exercises, error } = await supabase
  .from('exercises')
  .select('*')
  .eq('tp_id', tpNumber)
  .eq('materia', materia)
  .eq('is_active', true)
  .order('id', { ascending: true });

if (error) {
  console.error(`Error cargando ejercicios del TP ${tpNumber} de ${materia}:`, error);
}

const materiaFormateada = materia.charAt(0).toUpperCase() + materia.slice(1);
---

<div class="max-w-4xl mx-auto px-4 pb-8 pt-4">
    <details class="group" open={isOpen}>
        <summary class="list-none cursor-pointer focus:outline-none rounded-3xl ring-indigo-500/50 focus-visible:ring-2 transition-all">
            <header class="bg-white/5 border border-white/10 p-6 md:p-8 rounded-3xl flex flex-col md:flex-row items-center justify-between gap-4 backdrop-blur-md relative overflow-hidden transition-colors group-hover:bg-white/10">
                <div class="absolute inset-0 bg-gradient-to-r from-indigo-500/10 to-purple-500/10 z-0 pointer-events-none"></div>
                
                <div class="relative z-10 text-center md:text-left w-full md:w-auto flex-1">
                    <h2 class="text-white text-3xl md:text-4xl font-extrabold mb-2 tracking-tight">
                        Trabajo Práctico {tpNumber} - {materiaFormateada}
                    </h2>
                    <p class="text-gray-400 text-lg">
                        Ejercicios de resolución de la cátedra
                    </p>
                </div>

                <div class="relative z-10 bg-black/40 p-3 rounded-full border border-white/10 group-open:rotate-180 transition-transform duration-300 shadow-lg">
                    <svg class="size-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                </div>
            </header>
        </summary>

        <div class="space-y-6 relative mt-8 pt-2 animate-in fade-in slide-in-from-top-4 duration-500">

            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3/4 h-3/4 bg-indigo-500/10 blur-[120px] rounded-full z-[-1] pointer-events-none"></div>

            {error ? (
                <div class="bg-red-500/20 text-red-200 p-6 rounded-xl border border-red-500/30 text-center">
                    Hubo un error al cargar los ejercicios del TP {tpNumber}. Intenta recargar la página.
                </div>
            ) : (!exercises || exercises.length === 0) ? (
                <div class="bg-white/5 p-8 rounded-xl border border-white/10 text-center text-gray-400">
                    Aún no hay ejercicios habilitados para este TP de {materiaFormateada}. ¡Vuelve pronto!
                </div>
            ) : (
                exercises.map((exercise) => (
                    <article class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm shadow-xl transition-all duration-300 hover:bg-white/10">
                        
                        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-5">
                            <span class="bg-white text-black px-4 py-1.5 rounded-full font-bold text-sm shrink-0 shadow-[0_0_15px_rgba(255,255,255,0.3)]">
                                Ejercicio {exercise.id}
                            </span>
                            <h3 class="text-white font-semibold text-lg md:text-xl">{exercise.title}</h3>
                        </div>

                        <div class="bg-black/30 p-5 rounded-xl border-l-4 border-indigo-500 text-gray-300 leading-relaxed font-medium whitespace-pre-wrap select-none" set:html={exercise.description} />

                        {exercise.code_snippet && (
                            <div class="mt-6 relative group/code">
                                <div class="absolute inset-0 bg-gradient-to-r from-blue-500/20 to-indigo-500/20 rounded-xl blur-md"></div>
                                <div class="relative bg-[#0d1117] border border-white/10 rounded-xl shadow-2xl overflow-hidden">
                                    <div class="flex items-center px-4 py-3 bg-white/5 border-b border-white/5">
                                        <div class="flex space-x-2">
                                            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                                            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
                                            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
                                        </div>
                                        <span class="ml-4 text-xs text-gray-400 font-mono font-semibold select-none">script.py</span>
                                    </div>
                                    <pre class="p-5 text-sm md:text-base font-mono text-blue-300 overflow-x-auto select-none"><code class="whitespace-pre">{exercise.code_snippet}</code></pre>
                                </div>
                            </div>
                        )}

                        {(exercise.example_input || exercise.example_output) && (
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
                                {exercise.example_input && (
                                    <div class="bg-black/40 border border-white/5 rounded-xl p-4 font-mono text-sm">
                                        <div class="text-indigo-400 font-bold mb-2 flex items-center gap-2">
                                            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                            Ejemplo de Entrada
                                        </div>
                                        <p class="text-gray-300 whitespace-pre-wrap select-none">{exercise.example_input}</p>
                                    </div>
                                )}
                                
                                {exercise.example_output && (
                                    <div class="bg-black/40 border border-white/5 rounded-xl p-4 font-mono text-sm">
                                        <div class="text-green-400 font-bold mb-2 flex items-center gap-2">
                                            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                                            Salida Esperada
                                        </div>
                                        <p class="text-gray-300 whitespace-pre-wrap select-none">{exercise.example_output}</p>
                                    </div>
                                )}
                            </div>
                        )}
                    </article>
                ))
            )}
        </div>
    </details>
</div>

<style>
    /* Escondemos la flecha "fea" por defecto del navegador en los acordeones para usar la nuestra */
    details > summary {
        list-style: none;
    }
    details > summary::-webkit-details-marker {
        display: none;
    }
</style>
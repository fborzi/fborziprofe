---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Área de Estudiantes" description="Selecciona tu materia para ver los trabajos prácticos">
    <main class="flex flex-col items-center justify-center min-h-screen px-4 relative pt-20 pb-12">
        
        <!-- Luz de fondo general -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl h-3/4 bg-indigo-500/10 blur-[120px] rounded-full z-[-1] pointer-events-none"></div>

        <!-- Encabezado -->
        <div class="text-center mb-12 animate-in fade-in slide-in-from-bottom-4 duration-700">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-white tracking-tight">Área de Estudiantes</h1>
            <p class="text-lg text-gray-400 max-w-xl mx-auto">
                Seleccioná tu lenguaje de programación para acceder a los ejercicios y trabajos prácticos de la cursada.
            </p>
        </div>

        <!-- Grilla de Materias -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-4xl">
            
            <!-- TARJETA PYTHON -->
            <a 
                href="/estudiantes/python" 
                class="group relative flex flex-col items-center p-10 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl hover:bg-white/10 hover:border-[#3776AB]/50 hover:shadow-[0_0_40px_rgba(55,118,171,0.2)] transition-all duration-300 hover:-translate-y-2"
            >
                <!-- SVG Logo Python -->
                <div class="mb-6 group-hover:scale-110 transition-transform duration-300 drop-shadow-2xl">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 118 118" width="100" height="100">
                        <path d="M58.74 1.1c-28.84 0-27.27 12.56-27.27 12.56l.03 12.92h28.02v3.98H28.05s-13.06-1.57-13.06 18.06 12.43 18.8 12.43 18.8h9.32v-11.2c0-13.08 10.82-13.43 10.82-13.43h20.65s12.56.24 12.56-11.83V14.15s1.17-13.05-22.03-13.05z" fill="#387EB8"/>
                        <path d="M59.26 116.9c28.84 0 27.27-12.56 27.27-12.56l-.03-12.92H58.48v-3.98h31.47s13.06 1.57 13.06-18.06-12.43-18.8-12.43-18.8h-9.32v11.2c0 13.08-10.82 13.43-10.82 13.43H49.78s-12.56-.24-12.56 11.83v17.47s-1.17 13.05 22.04 13.05z" fill="#FFE052"/>
                        <circle cx="43.23" cy="14.48" r="3.73" fill="#fff"/>
                        <circle cx="74.77" cy="103.52" r="3.73" fill="#fff"/>
                    </svg>
                </div>
                <h2 class="text-3xl font-bold text-white mb-3 tracking-wide">Python</h2>
                <p class="text-gray-400 text-center text-sm">
                    Fundamentos, lógica de programación, estructuras de control y funciones.
                </p>
                <div class="mt-6 text-[#387EB8] font-semibold flex items-center gap-2 group-hover:gap-3 transition-all">
                    Ingresar <span class="text-xl">→</span>
                </div>
            </a>

            <!-- TARJETA JAVA -->
            <a 
                href="/estudiantes/java" 
                class="group relative flex flex-col items-center p-10 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl hover:bg-white/10 hover:border-[#EA2D2E]/50 hover:shadow-[0_0_40px_rgba(234,45,46,0.15)] transition-all duration-300 hover:-translate-y-2"
            >
                <!-- SVG Logo Java -->
                <div class="mb-6 group-hover:scale-110 transition-transform duration-300 drop-shadow-2xl">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 118 118" width="100" height="100">
                        <path fill="#EA2D2E" d="M72.1 8.2c-.3-.6-1.5-1-1.7-.5-1 2.2-3.7 3.5-3.3 6.6.2 1.6 1.8 2.6 1.5 4.3-.3 2-2.5 3-3.6 4.7-1.1 1.7-.6 4 1.4 5.2.2.1.5 0 .5-.2.2-1.3-.4-2.6 0-3.9.5-1.5 2.1-2 3.1-3.3 1-1.4.7-3.3.4-5-.3-1.6-1.2-2.8-1.5-4.4-.3-1.6.4-2.6 3.2-3.5zm-15.6 4.5c-.3-.6-1.5-.9-1.8-.4-.9 2.2-3.6 3.7-3.3 6.8.2 1.7 1.8 2.7 1.5 4.5-.3 2.1-2.5 3.1-3.6 4.9-1.2 1.8-.7 4.1 1.4 5.4.2.1.5 0 .6-.2.2-1.3-.5-2.7 0-4 .5-1.5 2.2-2.1 3.2-3.4 1-1.4.7-3.5.4-5.2-.3-1.7-1.3-2.9-1.6-4.6-.2-1.6.5-2.8 3.2-3.8zm11 15.6c-.3-.6-1.5-1-1.7-.4-1 2.1-3.7 3.5-3.4 6.6.2 1.6 1.8 2.6 1.5 4.3-.3 2-2.5 3-3.7 4.7-1.1 1.8-.6 4 1.4 5.2.2.1.5 0 .5-.2.2-1.3-.4-2.6 0-3.9.5-1.5 2.1-2 3.2-3.3 1-1.4.7-3.3.4-5-.3-1.6-1.2-2.8-1.5-4.4-.3-1.7.4-2.7 3.3-3.6z"/>
                        <path fill="#5382A1" d="M85 71.9c0-1-1.3-1.6-2.5-1.8-6.1-1.2-12.7-1.8-18.9-2.1-5.1-.2-10.2-.3-15.4-.3-4.1 0-8.2.1-12.3.4-3.1.2-6.2.5-9.3.9-1.6.2-3 .5-3.8 1.4-1.1 1.2-1.2 2.7.2 3.8 1.4 1.1 3.5 1.5 5.3 1.9 4 .8 8.1 1.3 12.2 1.7 7.6.7 15.3.9 22.9.8 4.7-.1 9.4-.3 14-.7 3.5-.3 7.3-.8 10.3-2.2 1.3-.6 2.3-1.5 2.3-2.8.2-1.8-4.9-1-5 .1m-35 8.9c-8.4 0-16.7.4-24.8 1.4-2.8.3-5.5.8-7.9 2.1-2 .9-3.2 2.2-2.8 3.9.4 1.7 2.3 2.7 4.1 3.3 3.4 1.2 7 1.9 10.6 2.4 8.7 1.2 17.5 1.4 26.3 1.3 6-.1 12-.4 17.8-1.2 3.8-.5 7.6-1.2 10.9-3 1.4-.7 2.4-1.7 2.4-3.1 0-1.7-1.6-2.7-3.3-3.4-4-1.6-8.3-2.3-12.6-2.8-6.6-.7-13.6-.9-20.7-.9m11.4 14.6c-7 .1-14 .5-20.9 1.3-2.8.3-5.5.8-7.9 1.9-1.6.7-2.6 1.7-2.4 3 .2 1.4 1.8 2.2 3.4 2.7 3.3 1 6.8 1.5 10.3 1.9 8 .9 16.1 1.1 24.3 1 5-.1 10.1-.4 15.1-1.1 3.5-.5 7.2-1.2 10.1-2.9 1.1-.6 1.8-1.4 1.8-2.6 0-1.3-1.1-2.1-2.4-2.6-3.4-1.3-7.1-1.9-10.8-2.3-6.8-.4-13.8-.3-20.6-.3m17.5-35c6.2 1.2 11.8 3.5 11.2 7.7-.5 3.3-4.7 5.2-8.5 6.4-1.3.4-2.8.8-4.3 1.1v-2.3c.6-.1 1.3-.2 1.9-.3 3.9-1 8.2-3.1 7.8-5.5-.3-1.8-3.4-3-6-3.8-1.5-.5-3.1-.8-4.8-1.1v-2.2z"/>
                    </svg>
                </div>
                <h2 class="text-3xl font-bold text-white mb-3 tracking-wide">Java</h2>
                <p class="text-gray-400 text-center text-sm">
                    Programación Orientada a Objetos, herencia, polimorfismo y clases.
                </p>
                <div class="mt-6 text-[#5382A1] font-semibold flex items-center gap-2 group-hover:gap-3 transition-all">
                    Ingresar <span class="text-xl">→</span>
                </div>
            </a>
            
        </div>
    </main>
</Layout>

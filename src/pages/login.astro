---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Login" description="Inicia sesión para acceder a los ejercicios">
    <!-- px-4 agrega la separación de los bordes en celulares -->
    <main class="flex flex-col items-center justify-center min-h-screen px-4 relative">
        
        <!-- Luz de fondo sutil (sigue el diseño de tu componente Tp.astro) -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg h-3/4 bg-indigo-500/20 blur-[120px] rounded-full z-[-1] pointer-events-none"></div>

        <!-- max-w-md limita el ancho máximo, w-full asegura que ocupe lo necesario, glassmorphism para el fondo -->
        <div class="w-full max-w-md p-8 sm:p-10 bg-white/5 backdrop-blur-xl shadow-2xl rounded-3xl border border-white/10 text-center relative overflow-hidden">
            
            <div class="mb-8">
                <!-- Ícono de usuario (opcional, le da un toque profesional) -->
                <!-- <div class="mx-auto w-16 h-16 bg-indigo-500/20 border border-indigo-500/30 rounded-full flex items-center justify-center mb-4 shadow-[0_0_15px_rgba(99,102,241,0.2)]">
                    <svg class="size-8 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div> -->
                
                <h1 class="text-3xl font-extrabold mb-2 text-white tracking-tight">Acceso Alumnos</h1>
                <p class="text-gray-400">
                    Ingresá con tu cuenta de GitHub para acceder a los trabajos prácticos.
                </p>
            </div>

            <button
                id="loginBtn"
                class="w-full bg-[#24292e] text-white border border-white/10 px-6 py-3.5 rounded-xl font-medium hover:bg-[#2f363d] hover:border-white/20 hover:shadow-lg transition-all flex items-center justify-center gap-3 disabled:opacity-70 disabled:cursor-not-allowed group"
            >
                <!-- Usamos una animación de "pulse" sutil al hacer hover -->
                <img
                    src="/GitHub_Invertocat_White_Clearspace.png"
                    alt="GitHub"
                    class="size-6 group-hover:scale-110 transition-transform"
                />
                <span id="btnText">Sign in with GitHub</span>
            </button>
        </div>
    </main>
</Layout>

<script>
    import { supabase } from "../lib/supabase";
    
    const setupLogin = () => {
        const loginBtn = document.querySelector("#loginBtn") as HTMLButtonElement;
        const btnText = document.querySelector("#btnText");

        loginBtn?.addEventListener("click", async () => {
            // 1. Feedback visual de carga (bloqueamos el botón para evitar doble clic)
            loginBtn.disabled = true;
            if (btnText) btnText.textContent = "Conectando...";
            
            // 2. Proceso de Autenticación
            const { error } = await supabase.auth.signInWithOAuth({
                provider: "github",
                options: {
                    redirectTo: window.location.origin + "/auth/callback",
                },
            });
            
            // 3. Manejo de error (si el usuario cancela o falla la red)
            if (error) {
                console.error("Error:", error);
                loginBtn.disabled = false;
                if (btnText) btnText.textContent = "Sign in with GitHub";
                // Sería ideal mostrar un toast/notificación aquí
            }
        });
    };
    
    setupLogin();
</script>

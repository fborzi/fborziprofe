---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import chiringuitosImg from '../assets/chiringuitos.png';
import llaRojasImg from '../assets/llarojas.png';
import botImg from '../assets/bot.png';

interface Project {
  title: string;
  description: string;
  theme: string;
  href: string;
  image: ImageMetadata;
}

const projects: Project[] = [
  {
    title: "Chiringuitos House",
    description: "Landing page para complejo de cabañas en la costa.",
    theme: "from-stone-800 to-green-900",
    href: "https://chiringuitoshouse.com.ar",
    image: chiringuitosImg,
  },
  {
    title: "Web Institucional LLA Rojas",
    description: "Desarrollo web completo (llarojas.com.ar), maquetación de noticias y gestión de correos.",
    theme: "from-slate-800 to-slate-600",
    image: llaRojasImg,
    href: "https://llarojas.com.ar",
  },
  {
    title: "Bots & Herramientas Laborales",
    description: "Bot 'Daily Presenter' para el equipo, validadores de datos con Python para mallas de control m, scripts de automatización de pruebas, entre otros.",
    theme: "from-blue-900 to-cyan-800",
    image: botImg,
    href: "",
  },
  {
    title: "Bots & Herramientas Personales",
    description: "Tracker de BTC vía WhatsApp, validaciones con App Script en diferentes herramientas de Google Workspace, entre otros.",
    theme: "from-zinc-800 to-zinc-900",
    image: botImg,
    href: ""
  }
];
---

<Layout 
  title="Franco Borzi | Software Engineer & Web Developer" 
  description="Portfolio personal y portal académico de Franco Borzi."
>
  <main class="flex flex-col gap-24 pb-24">
    
    <section class="mx-auto max-w-7xl px-4 pt-32 sm:px-6 lg:px-8 flex flex-col items-start justify-center min-h-[70vh]">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl max-w-3xl">
        Franco Borzi <br />
        <span class="text-gray-400">Software Engineer & Web Developer</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-gray-300">
        Diseño arquitecturas de datos para el sector financiero, construyo soluciones web de alto rendimiento y formo a la próxima generación de desarrolladores.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a 
          href="#proyectos" 
          class="inline-flex items-center justify-center rounded-md bg-white px-6 py-3 text-base font-medium text-black shadow-sm hover:bg-gray-200 transition-all focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#1f1f1f]"
        >
          Ver mis proyectos
        </a>
        <a 
          href="/estudiantes" 
          class="inline-flex items-center justify-center rounded-md border border-white/20 bg-white/5 backdrop-blur-sm px-6 py-3 text-base font-medium text-white shadow-sm hover:bg-white/10 transition-all focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#1f1f1f]"
        >
          Acceso Estudiantes
        </a>
      </div>
    </section>

    <section id="servicios" class="scroll-mt-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold tracking-tight text-white mb-12">Áreas de Conocimiento</h2>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">

          <article class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-8 shadow-xl transition-colors hover:bg-white/10">
            <h3 class="text-xl font-semibold text-white">Backend & Data Engineering</h3>
            <p class="mt-4 text-gray-400">
              Diseño de soluciones de ingesta y arquitecturas de convivencia (Legacy/Oracle). Optimización de cachés en memoria para procesamiento masivo de datos con <strong>Apache Spark</strong> y diseño de APIs robustas de alto rendimiento usando <strong>Spring Boot</strong>.
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Java (Spring Boot)</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Apache Spark</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Python</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">PySpark</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Oracle DB</span>
            </div>
          </article>

          <article class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-8 shadow-xl transition-colors hover:bg-white/10">
            <h3 class="text-xl font-semibold text-white">Automatización & DX</h3>
            <p class="mt-4 text-gray-400">
              Creación de herramientas internas y pipelines CI/CD para optimizar la experiencia del desarrollador (DX). Automatización de QA productivo, adecuación de mallas mediante manipulación XML y monitoreo de procesos.
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Control-M</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">GitHub Actions</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">CI/CD</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Python Tooling</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">XML Processing</span>
            </div>
          </article>

          <article class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-8 shadow-xl transition-colors hover:bg-white/10">
            <h3 class="text-xl font-semibold text-white">Desarrollo Web & Marca Digital</h3>
            <p class="mt-4 text-gray-400">
              Construcción de sitios modernos y de alta performance, respaldados por un servicio de gestión y mantenimiento continuo. Coordino y entrego soluciones digitales integrales: desde la arquitectura técnica y el manual de marca, hasta la estrategia de contenido.
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Astro</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Tailwind CSS</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Svelte</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Supabase</span>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-gray-300 border border-white/5">Branding</span>
            </div>
          </article>

        </div>
      </div>
    </section>

    <section id="logros" class="scroll-mt-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold tracking-tight text-white mb-12">Impacto y Logros Corporativos</h2>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          
          <article class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-8 shadow-xl transition-colors hover:bg-white/10">
            <h3 class="text-xl font-semibold text-white">Automatización de Despliegues y Entornos</h3>
            <p class="mt-4 text-gray-400">
              Desarrollo de utilidades en Python para la <strong>adecuación automatizada de mallas de ejecución entre entornos</strong> (Dev a Prod) mediante manipulación de XML. Reduje drásticamente la intervención manual y el riesgo de error humano en la configuración de dependencias y rutas de jobs críticos.
            </p>
          </article>

          <article class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-8 shadow-xl transition-colors hover:bg-white/10">
            <h3 class="text-xl font-semibold text-white">Arquitectura de Pruebas y Optimización de Pipelines</h3>
            <p class="mt-4 text-gray-400">
              Lideré la refactorización del componente de contratos mediante parametrización, logrando desacoplar dependencias y permitiendo probar contratos de forma aislada. Además, rediseñé la malla de ejecución consolidando docenas de <em class="text-gray-300">File Watchers</em> secuenciales en un único proceso <em class="text-gray-300">config-driven</em>. Esto eliminó bloqueos por asincronía de archivos y redujo masivamente la cantidad de jobs en Control-M.
            </p>
          </article>

          <article class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-8 shadow-xl transition-colors hover:bg-white/10">
            <h3 class="text-xl font-semibold text-white">Gobernanza de Datos y QA Productivo</h3>
            <p class="mt-4 text-gray-400">
              Ingeniería de flujos de validación automática para datos productivos. Reemplacé controles manuales intensivos por scripts centralizados, unificando la carga operativa de múltiples analistas en un único proceso automatizado y confiable.
            </p>
          </article>

          <article class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-8 shadow-xl transition-colors hover:bg-white/10">
            <h3 class="text-xl font-semibold text-white">Cultura Tech, Mentoring & Tooling</h3>
            <p class="mt-4 text-gray-400">
              Liderazgo técnico en la adopción de nuevas herramientas, impulsando al equipo a integrar Python y Apps Script en sus flujos de trabajo diarios. Facilitación del <em class="text-gray-300">onboarding</em> mediante documentación estructurada y sesiones de capacitación. Además, demostré fuerte <em class="text-gray-300">ownership</em> desarrollando bots de gestión ágil para resolver fricciones históricas de organización.
            </p>
          </article>

        </div>
      </div>
    </section>

    <section id="proyectos" class="scroll-mt-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold tracking-tight text-white mb-12">Proyectos Destacados</h2>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {projects.map((project) => (
            <article class="group relative flex flex-col items-start justify-end overflow-hidden rounded-2xl bg-black px-8 pb-8 pt-40 sm:pt-48 lg:pt-64 border border-white/10 transition-all hover:border-white/30">
              
              {project.href && (
                <a href={project.href} target="_blank" rel="noopener noreferrer" class="absolute inset-0 z-50">
                  <span class="sr-only">Ir al proyecto {project.title}</span>
                </a>
              )}

              { project.image && (
                <Image 
                  src={project.image} 
                  alt={`Captura del proyecto ${project.title}`} 
                  class="absolute inset-0 z-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  widths={[400, 800]}
                  sizes="(max-width: 768px) 100vw, 50vw"
                />
              )}

              <div class={`absolute inset-0 z-10 bg-gradient-to-br ${project.theme} opacity-80 transition-transform duration-500 group-hover:scale-105`}></div>
              
              <div class="absolute inset-0 z-20 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>
              
              <h3 class="relative z-30 mt-3 text-2xl font-semibold leading-6 text-white">
                {project.title}
              </h3>
              <p class="relative z-30 mt-2 text-sm leading-6 text-gray-300">
                {project.description}
              </p>

            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="estudiantes" class="scroll-mt-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="relative isolate overflow-hidden bg-white/5 backdrop-blur-md px-6 py-24 text-center shadow-2xl rounded-3xl border border-white/10 sm:px-16">
          <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Espacio Académico</h2>
          <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-gray-300">
            Área exclusiva para mis alumnos universitarios. Accedé a repositorios de ejercicios en Java & Python.
          </p>
          <div class="mt-10 flex items-center justify-center gap-x-6">
            <a 
              href="/estudiantes" 
              class="rounded-md bg-indigo-500 px-8 py-4 text-lg font-semibold text-white shadow-sm hover:bg-indigo-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500 transition-all"
            >
              Ir al Portal de Estudiantes
            </a>
          </div>
        </div>
      </div>
    </section>

    
  </main>

  <footer class="border-t border-white/10 bg-black/20 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex space-x-6 text-gray-400">
        <a href="https://linkedin.com/in/francoborzi" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
          <span class="sr-only">LinkedIn</span>
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" /></svg>
        </a>
        <a href="https://github.com/fborzi" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
          <span class="sr-only">GitHub</span>
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
        </a>
        <a href="mailto:francoborzi@hotmail.com" class="hover:text-white transition-colors">
          <span class="sr-only">Email</span>
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
      </div>
      <p class="text-sm leading-5 text-gray-500 text-center md:text-left">
        Diseñado y desarrollado por Franco Borzi - 2026
      </p>
    </div>
  </footer>
</Layout>